void handleAttivaWeb() {
  if (!verificaUtente()) { server.sendHeader("Location", "/login"); server.send(303); return; }
  if (server.hasArg("p") && server.hasArg("t")) {
    String pompaId = server.arg("p");
    unsigned long nuovoTempo = server.arg("t").toInt() * 1000UL;

    if (pompaId == "1" && !pompa1Attiva && serbatoioOk()) {
      DURATA_POMPA1_MS = nuovoTempo;
      digitalWrite(PIN_RELE_POMPA1, LOW);
      pompa1Attiva = true;
      timerPompa1  = millis();
      conteggioPompa1++;
    } else if (pompaId == "2" && !pompa2Attiva && serbatoioOk()) {
      DURATA_POMPA2_MS = nuovoTempo;
      digitalWrite(PIN_RELE_POMPA2, LOW);
      pompa2Attiva = true;
      timerPompa2  = millis();
      conteggioPompa2++;
    }
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

void handleStop() {
  if (!verificaUtente()) { server.sendHeader("Location", "/login"); server.send(303); return; }
  if (server.hasArg("p")) {
    String pompaId = server.arg("p");
    if (pompaId == "1") {
      digitalWrite(PIN_RELE_POMPA1, HIGH);
      pompa1Attiva = false;
    } else if (pompaId == "2") {
      digitalWrite(PIN_RELE_POMPA2, HIGH);
      pompa2Attiva = false;
    }
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n--- SYSTEM IRRIGATION STARTING ---");

  EEPROM.begin(64);
  uint8_t magic = EEPROM.read(EEPROM_ADDR_MAGIC);
  if (magic != EEPROM_MAGIC_VAL) {
    eepromWriteUint32(EEPROM_ADDR_TIMESTAMP, 0);
    EEPROM.write(EEPROM_ADDR_GIORNO_P2, EEPROM_DAY_EMPTY);
    EEPROM.write(EEPROM_ADDR_MAGIC, EEPROM_MAGIC_VAL);
    
    // Default initial values (10 seconds)
    EEPROM.write(EEPROM_ADDR_ORA_P1, 8);
    EEPROM.write(EEPROM_ADDR_MIN_P1, 0);
    eepromWriteUint32(EEPROM_ADDR_DUR_P1, 10UL * 1000UL);

    EEPROM.write(EEPROM_ADDR_ORA_P2, 8);
    EEPROM.write(EEPROM_ADDR_MIN_P2, 2);
    EEPROM.write(EEPROM_ADDR_GIORNO_P2_SET, 6); // Saturday
    eepromWriteUint32(EEPROM_ADDR_DUR_P2, 10UL * 1000UL);
    EEPROM.commit();
    
    ultimoTimestampPompa1 = 0;
    ultimoGiornoPompa2    = EEPROM_DAY_EMPTY;
  } else {
    ultimoTimestampPompa1 = eepromReadUint32(EEPROM_ADDR_TIMESTAMP);
    ultimoGiornoPompa2    = EEPROM.read(EEPROM_ADDR_GIORNO_P2);
    
    // Load configurations from EEPROM
    ORA_POMPA1      = EEPROM.read(EEPROM_ADDR_ORA_P1);
    MINUTO_POMPA1   = EEPROM.read(EEPROM_ADDR_MIN_P1);
    DURATA_POMPA1_MS = eepromReadUint32(EEPROM_ADDR_DUR_P1);

    ORA_POMPA2      = EEPROM.read(EEPROM_ADDR_ORA_P2);
    MINUTO_POMPA2   = EEPROM.read(EEPROM_ADDR_MIN_P2);
    GIORNO_POMPA2   = EEPROM.read(EEPROM_ADDR_GIORNO_P2_SET);
    DURATA_POMPA2_MS = eepromReadUint32(EEPROM_ADDR_DUR_P2);
  }

  pinMode(PIN_RELE_POMPA1, OUTPUT);
  pinMode(PIN_RELE_POMPA2, OUTPUT);
  digitalWrite(PIN_RELE_POMPA1, HIGH);
  digitalWrite(PIN_RELE_POMPA2, HIGH);

  Wire.begin(21, 22); // SDA = 21, SCL = 22
  if (!rtc.begin()) {
    Serial.println("ERROR: RTC module not found!");
  } else {
    Serial.println("RTC module successfully initialized.");
  }

  Serial.print("Connecting to Wi-Fi network: ");
  Serial.println(ssid);
  WiFi.begin(ssid, password);
  
  int tentativi = 0;
  while (WiFi.status() != WL_CONNECTED && tentativi < 30) {
    delay(500);
    Serial.print(".");
    tentativi++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nSuccessfully connected!");
    Serial.print("ESP32 IP Address: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("\nFailed to connect to Wi-Fi!");
  }

  server.on("/", handleRoot);
  server.on("/login", handleLogin);
  server.on("/logout", handleLogout);
  server.on("/attivaWeb", handleAttivaWeb);
  server.on("/stop", handleStop);
  server.on("/salvaP1", handleSalvaP1);
  server.on("/salvaP2", handleSalvaP2);
  server.on("/sincronizzaOra", handleSincronizzaOra);
  
  const char* headerkeys[] = {"Cookie"};
  size_t headerkeyssize = sizeof(headerkeys)/sizeof(char*);
  server.collectHeaders(headerkeys, headerkeyssize);
  
  server.begin();
  Serial.println("Web server started on port 80.");
}

void loop() {
  server.handleClient();

  DateTime now = rtc.now();
  uint8_t  ora    = now.hour();
  uint8_t  minuto = now.minute();
  uint8_t  giorno = now.day();
  uint8_t  gSett  = now.dayOfTheWeek();
  uint32_t ts     = now.unixtime();

  static uint8_t ultimoGiornoRilevato = 0xFF;
  if (giorno != ultimoGiornoRilevato) {
    ultimoGiornoRilevato  = giorno;
    pompa1OggiEseguita    = false;
    pompa2OggiEseguita    = false;
  }

  // Automatic Pump 1 start (Every 2 days)
  if (ora == ORA_POMPA1 && minuto == MINUTO_POMPA1 && !pompa1OggiEseguita && !pompa1Attiva) {
    bool intervalloRispettato = (ultimoTimestampPompa1 == 0) || (ts - ultimoTimestampPompa1) >= INTERVALLO_POMPA1_SEC;
    if (intervalloRispettato) {
      if (serbatoioOk()) {
        digitalWrite(PIN_RELE_POMPA1, LOW);
        pompa1Attiva        = true;
        timerPompa1         = millis();
        pompa1OggiEseguita  = true;
        conteggioPompa1++;
      } else {
        pompa1OggiEseguita  = true;
      }
    } else {
      pompa1OggiEseguita = true;
    }
  }

  // Automatic Pump 2 start (Once a week - e.g., Saturday)
  if (ora == ORA_POMPA2 && minuto == MINUTO_POMPA2 && gSett == GIORNO_POMPA2 && !pompa2OggiEseguita && !pompa2Attiva) {
    if (ultimoGiornoPompa2 != giorno) {
      if (serbatoioOk()) {
        digitalWrite(PIN_RELE_POMPA2, LOW);
        pompa2Attiva        = true;
        timerPompa2         = millis();
        pompa2OggiEseguita  = true;
        conteggioPompa2++;
      } else {
        pompa2OggiEseguita  = true;
      }
    } else {
      pompa2OggiEseguita = true;
    }
  }

  if (pompa1Attiva && (millis() - timerPompa1 >= DURATA_POMPA1_MS)) {
    digitalWrite(PIN_RELE_POMPA1, HIGH);
    pompa1Attiva         = false;
    pompa1HaFinitoDaPoco = true;
    ultimoTimestampPompa1 = ts;
  }

  if (pompa2Attiva && (millis() - timerPompa2 >= DURATA_POMPA2_MS)) {
    digitalWrite(PIN_RELE_POMPA2, HIGH);
    pompa2Attiva         = false;
    pompa2HaFinitoDaPoco = true;
    ultimoGiornoPompa2   = giorno;
  }

  if (pompa1HaFinitoDaPoco) { salvaStatoFinalePompa1(); pompa1HaFinitoDaPoco = false; }
  if (pompa2HaFinitoDaPoco) { salvaStatoFinalePompa2(); pompa2HaFinitoDaPoco = false; }

  delay(10);
}
