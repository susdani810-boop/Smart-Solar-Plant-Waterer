// --- ACCESS LOG STRUCT ---
struct RegistroAccesso {
  String ip;
  String orario;
};

#define MAX_LOG 5
RegistroAccesso ultimiAccessi[MAX_LOG];
int indiceLog = 0;

String ipAttivoAttuale = "None";
unsigned long ultimoContattoAttivo = 0;

void registraAccesso(String ip, String orarioCorrente) {
  ipAttivoAttuale = ip;
  ultimoContattoAttivo = millis();

  if (indiceLog > 0 && ultimiAccessi[indiceLog - 1].ip == ip) {
    ultimiAccessi[indiceLog - 1].orario = orarioCorrente;
    return;
  }

  if (indiceLog >= MAX_LOG) {
    for (int i = 1; i < MAX_LOG; i++) {
      ultimiAccessi[i - 1] = ultimiAccessi[i];
    }
    indiceLog = MAX_LOG - 1;
  }

  ultimiAccessi[indiceLog].ip = ip;
  ultimiAccessi[indiceLog].orario = orarioCorrente;
  indiceLog++;
}

void eepromWriteUint32(int addr, uint32_t value) {
  EEPROM.write(addr + 0, (value >>  0) & 0xFF);
  EEPROM.write(addr + 1, (value >>  8) & 0xFF);
  EEPROM.write(addr + 2, (value >> 16) & 0xFF);
  EEPROM.write(addr + 3, (value >> 24) & 0xFF);
  EEPROM.commit();
}

uint32_t eepromReadUint32(int addr) {
  uint32_t value = 0;
  value |= ((uint32_t)EEPROM.read(addr + 0)) <<  0;
  value |= ((uint32_t)EEPROM.read(addr + 1)) <<  8;
  value |= ((uint32_t)EEPROM.read(addr + 2)) << 16;
  value |= ((uint32_t)EEPROM.read(addr + 3)) << 24;
  return value;
}

