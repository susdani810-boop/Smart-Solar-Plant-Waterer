    }
  }
  return false;
}

// --- LOGIN SCREEN ---
void handleLogin() {
  String msg = "";
  
  if (server.hasArg("password")) {
    String inputPass = server.arg("password");
    DateTime now = rtc.now();
    String orarioLog = String(now.hour()) + ":" + (now.minute() < 10 ? "0" : "") + String(now.minute()) + " - " + String(now.day()) + "/" + String(now.month());

    if (inputPass == PASSWORD_ADMIN) {
      registraAccesso(server.client().remoteIP().toString() + " (ADMIN)", orarioLog);
      server.sendHeader("Set-Cookie", "RUOLO=ADMIN; Path=/; Max-Age=86400");
      server.sendHeader("Location", "/");
      server.send(303);
      return;
    }
    else if (inputPass == PASSWORD_SITO) {
      registraAccesso(server.client().remoteIP().toString() + " (USER)", orarioLog);
      server.sendHeader("Set-Cookie", "RUOLO=UTENTE; Path=/; Max-Age=86400");
      server.sendHeader("Location", "/");
      server.send(303);
      return;
    }
    else {
      msg = "<p style='color:red;font-weight:bold;'>Incorrect Password!</p>";
    }
  }

  String html = "<!DOCTYPE html><html><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'>";
