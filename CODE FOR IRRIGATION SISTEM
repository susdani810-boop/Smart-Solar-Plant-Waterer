// CONFIGURAZIONE UTENTE (DA PERSONALIZZARE)
// ==========================================
const char* ssid     = "IL_TUO_WIFI";
const char* password = "LA_TUA_PASSWORD";

// PASSWORD DI ACCESSO AL PANNELLO WEB
const char* PASSWORD_SITO  = "user123";    // Password generale per usare il sito
const char* PASSWORD_ADMIN = "admin123";   // Password speciale per sbloccare la modalità ADMIN

// CONFIGURAZIONE FUSO ORARIO (Default: Europa/Roma)
// Gestisce in automatico Ora Solare (CET, +1) e Ora Legale (CEST, +2)
const char* FUSO_ORARIO = "CET-1CEST,M3.5.0,M10.5.0/3"; 
const char* NTP_SERVER  = "pool.ntp.org";
