bool verificaUtente() {
  if (server.hasHeader("Cookie")) {
    String cookie = server.header("Cookie");
    if (cookie.indexOf("RUOLO=UTENTE") != -1 || cookie.indexOf("RUOLO=ADMIN") != -1) {
      return true;
    }
  }
  return false;
}

bool verificaAdmin() {
  if (server.hasHeader("Cookie")) {
