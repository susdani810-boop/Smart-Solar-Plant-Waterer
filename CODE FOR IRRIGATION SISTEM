// --- PHONE TIME SYNCHRONIZATION ---
void handleSincronizzaOra() {
  if (!verificaUtente()) {
    server.send(401, "text/plain", "Unauthorized");
    return;
  }
  if (server.hasArg("ts")) {
    unsigned long clientTs = server.arg("ts").toInt();
    if (clientTs > 1700000000UL) {
      rtc.adjust(DateTime(clientTs));
      server.send(200, "text/plain", "OK");
      return;
    }
  }
  server.send(400, "text/plain", "Timestamp Error");
}

// --- SAVE PUMP 1 CONFIGURATIONS ---
void handleSalvaP1() {
  if (!verificaUtente()) { server.sendHeader("Location", "/login"); server.send(303); return; }
  if (server.hasArg("oraP1") && server.hasArg("minP1") && server.hasArg("durP1")) {
    ORA_POMPA1      = server.arg("oraP1").toInt();
    MINUTO_POMPA1   = server.arg("minP1").toInt();
    DURATA_POMPA1_MS = server.arg("durP1").toInt() * 1000UL;

    EEPROM.write(EEPROM_ADDR_ORA_P1, ORA_POMPA1);
    EEPROM.write(EEPROM_ADDR_MIN_P1, MINUTO_POMPA1);
    eepromWriteUint32(EEPROM_ADDR_DUR_P1, DURATA_POMPA1_MS);
    EEPROM.commit();
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

// --- SAVE PUMP 2 CONFIGURATIONS ---
void handleSalvaP2() {
  if (!verificaUtente()) { server.sendHeader("Location", "/login"); server.send(303); return; }
  if (server.hasArg("oraP2") && server.hasArg("minP2") && server.hasArg("giornoP2") && server.hasArg("durP2")) {
    ORA_POMPA2 = server.arg("oraP2").toInt();
    MINUTO_POMPA2 = server.arg("minP2").toInt();
    GIORNO_POMPA2 = server.arg("giornoP2").toInt();
    DURATA_POMPA2_MS = server.arg("durP2").toInt() * 1000UL;

    EEPROM.write(EEPROM_ADDR_ORA_P2, ORA_POMPA2);
    EEPROM.write(EEPROM_ADDR_MIN_P2, MINUTO_POMPA2);
    EEPROM.write(EEPROM_ADDR_GIORNO_P2_SET, GIORNO_POMPA2);
    eepromWriteUint32(EEPROM_ADDR_DUR_P2, DURATA_POMPA2_MS);
    EEPROM.commit();
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

